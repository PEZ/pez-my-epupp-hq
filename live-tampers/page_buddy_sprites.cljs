(ns page-buddy-sprites)

(def frame-size {:w 48 :h 32})

(def walk-data "data:image/png;base64,")

(def idle-data "data:image/png;base64,")

(def run-data "data:image/png;base64,")

(def sit-data "data:image/png;base64,")

(def sleep-data "data:image/png;base64,")

(def jump-data "data:image/png;base64,")

(def meow-data "data:image/png;base64,")

(def climb-data "data:image/png;base64,")

(def climb-idle-data "data:image/png;base64,")

(def touch-data "data:image/png;base64,")

(def being-hit-data "data:image/png;base64,")

(def stunned-data "data:image/png;base64,")

(def animations
  {:walk    {:frames 3
             :data walk-data}
   :idle    {:frames 8
             :data idle-data}
   :run     {:frames 5
             :data run-data}
   :sit     {:frames 10
             :data sit-data}
   :sleep   {:frames 12
             :data sleep-data}
   :jump    {:frames 8
             :data jump-data}
   :meow    {:frames 3
             :data meow-data}
   :climb   {:frames 7
             :data climb-data}
   :climb-idle {:frames 4
                :data climb-idle-data}
   :touch      {:frames 3
                :data touch-data}
   :being-hit  {:frames 3
                :data being-hit-data}
   :stunned    {:frames 6
                :data stunned-data}})
